<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <Style src="project://database/Assets/Modules/KSP2UnityTools/Assets/UITK for KSP2/Templates/ColorPicker/ColorPickerUI.uss?fileID=7433441132597879392&amp;guid=1f2c53d82160dff44a6bf621910ef831&amp;type=3#ColorPickerUI" />
    <ui:VisualElement name="ColorPicker">
        <ui:Slider name="HueSlider" orientation="Horizontal" low-value="0" high-value="255" />
        <ui:VisualElement name="SBSquareAlphaSliderContainer">
            <ui:VisualElement name="SBSquareBackground">
                <ui:VisualElement name="SBSquare">
                    <ui:VisualElement name="SBHandle" />
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="AlphaSliderBackground">
                <ui:Slider name="AlphaSlider" orientation="Vertical" direction="Vertical" low-value="0" high-value="255" style="height: 100%;" />
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
