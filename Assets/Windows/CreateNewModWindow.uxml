<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <ui:TextField picking-mode="Ignore" label="Mod Id" value="filler text" />
    <ui:Toggle label="Add Code To Mod" />
    <ui:VisualElement style="flex-grow: 0; background-color: rgba(0, 0, 0, 0); flex-direction: row;">
        <ui:Button text="Create" display-tooltip-when-elided="true" name="Create" style="width: 48%; margin-left: 1%; margin-right: 1%; margin-top: 1%; margin-bottom: 1%; flex-shrink: 1;" />
        <ui:Button text="Cancel" display-tooltip-when-elided="true" name="Cancel" style="width: 48%; margin-left: 1%; margin-right: 1%; margin-top: 1%; margin-bottom: 1%; flex-shrink: 1;" />
    </ui:VisualElement>
</ui:UXML>
