.transform-group-field {
    flex-direction: row;
    align-items: center;
}

.transform-group-field__autocomplete {
    flex-grow: 1;
}

.transform-group-field__match-chip {
    flex-shrink: 0;
    margin-left: 6px;
    font-size: 11px;
}

.transform-group-field__match-chip--ok {
    color: rgb(180, 195, 215);
}

.transform-group-field__match-chip--none {
    color: rgb(220, 130, 130);
}
